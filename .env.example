# ─────────────────────────────────────────────
#  FreshBite Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://freshbite_admin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/freshbite

# JWT secret key — make this long and random
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_random_and_long

# Server port (Render uses 10000, local use 5000)
PORT=5000

# Frontend URL for CORS (your Netlify URL)
CLIENT_URL=https://your-freshbite-site.netlify.app

# Razorpay keys (get from razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional: Admin email/password for seed script
ADMIN_EMAIL=admin@freshbite.com
ADMIN_PASSWORD=admin123
